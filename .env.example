# ================================================================
# NUCLEAR IDEAS — MILJÖVARIABLER
# ================================================================
# Kopiera: cp .env.example .env
# Fyll i dina riktiga värden i .env
# DELA ALDRIG .env publikt — den är i .gitignore
# ================================================================

# ----- Server -----
PORT=3000
NODE_ENV=development        # Ändra till "production" på servern

# ----- Stripe -----
# Hämta från: https://dashboard.stripe.com/apikeys
# Test: börjar med sk_test_ (testkortnr: 4242 4242 4242 4242)
# Live: börjar med sk_live_
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook-hemlighet (hämtas från Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----- E-post (valfritt men rekommenderat) -----
# Gmail-tips: Skapa App-lösenord på myaccount.google.com/apppasswords
# Alternativ: SendGrid, Brevo, Mailgun (alla har gratis-tier)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=hej@nuclear-ideas.se
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=Nuclear Ideas <hej@nuclear-ideas.se>

# ----- Admin -----
# Skyddar /api/booking/list och DELETE-endpoints.
# Generera: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=byt-ut-mot-ett-slumpmassigt-langt-varde
